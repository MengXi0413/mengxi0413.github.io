---
import type { CollectionEntry } from 'astro:content';
import { getSectionBySlug } from '../config/sections';
import FormattedDate from './FormattedDate.astro';
import TagList from './TagList.astro';

interface Props {
	post: CollectionEntry<'posts'>;
	compact?: boolean;
}

const { post, compact = false } = Astro.props;
const section = getSectionBySlug(post.data.section);
---

<article class:list={['post-card', compact && 'post-card--compact']}>
	<a class="post-card__cover" href={`/posts/${post.id}/`} style={`--section-accent: ${section.color};`}>
		{
			post.data.cover ? (
				<img src={post.data.cover} alt={post.data.coverAlt ?? post.data.title} loading="lazy" />
			) : (
				<div class="cover-fallback">
					<span>{section.mark}</span>
				</div>
			)
		}
	</a>
	<div class="post-card__content">
		<div class="post-card__meta">
			<span class="section-pill">{section.name}</span>
			<FormattedDate date={post.data.pubDate} />
		</div>
		<div>
			<h3>
				<a href={`/posts/${post.id}/`}>{post.data.title}</a>
			</h3>
			<p class="post-card__excerpt">{post.data.description}</p>
		</div>
		<TagList tags={post.data.tags.slice(0, compact ? 2 : 3)} />
	</div>
</article>
