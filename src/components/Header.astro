---
import { siteConfig } from '../config/site';

const currentPath = Astro.url.pathname;
const navItems = [
	{ href: '/', label: '首页' },
	{ href: '/section/kaoyan/', label: '考研日记' },
	{ href: '/section/chip-design/', label: '学习心得' },
	{ href: '/section/life/', label: '日常琐事' },
	{ href: '/archive/', label: '归档' },
	{ href: '/tags/', label: '标签' },
	{ href: '/about/', label: '关于' },
];

const isActive = (href: string) => {
	if (href === '/') {
		return currentPath === '/';
	}

	return currentPath.startsWith(href);
};
---

<header class="site-header">
	<div class="shell site-header__inner">
		<a class="site-brand" href="/">
			<span class="site-brand__mark">M</span>
			<span class="site-brand__text">
				<strong>{siteConfig.title}</strong>
				<small>{siteConfig.tagline}</small>
			</span>
		</a>
		<nav class="site-nav site-nav--desktop" aria-label="主导航">
			{
				navItems.map((item) => (
					<a href={item.href} class:list={['site-nav__link', isActive(item.href) && 'is-active']}>
						{item.label}
					</a>
				))
			}
		</nav>
		<details class="mobile-nav">
			<summary class="mobile-nav__toggle" aria-label="打开导航菜单">
				<span class="mobile-nav__icon" aria-hidden="true">
					<span></span>
					<span></span>
					<span></span>
				</span>
			</summary>
			<nav class="site-nav site-nav--mobile" aria-label="移动端主导航">
				{
					navItems.map((item) => (
						<a href={item.href} class:list={['site-nav__link', isActive(item.href) && 'is-active']}>
							{item.label}
						</a>
					))
				}
			</nav>
		</details>
	</div>
</header>
