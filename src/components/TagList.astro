---
import { getTagHref } from '../utils/content';

interface Props {
	tags: string[];
}

const { tags } = Astro.props;
---

{
	tags.length > 0 && (
		<ul class="tag-list" aria-label="文章标签">
			{tags.map((tag) => (
				<li>
					<a class="tag-pill" href={getTagHref(tag)}>
						#{tag}
					</a>
				</li>
			))}
		</ul>
	)
}
