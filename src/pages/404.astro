---
import MainLayout from '../layouts/MainLayout.astro';
import { siteConfig } from '../config/site';
---

<MainLayout title={`未找到页面 | ${siteConfig.title}`} description="这个页面不存在，回到首页继续浏览。">
	<section class="shell page-intro">
		<p class="eyebrow">404</p>
		<h1>这一页好像被时间带走了</h1>
		<div class="empty-state">
			<p>你访问的页面不存在，或者链接已经变动。</p>
			<p><a class="button-link button-link--primary" href="/">返回首页</a></p>
		</div>
	</section>
</MainLayout>
