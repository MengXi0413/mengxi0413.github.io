---
import MainLayout from '../../layouts/MainLayout.astro';
import { siteConfig } from '../../config/site';
import { getAllTags, getPublishedPosts, getTagHref } from '../../utils/content';

const posts = await getPublishedPosts();
const tags = getAllTags(posts).map((tag) => ({
	name: tag,
	count: posts.filter((post) => post.data.tags.includes(tag)).length,
}));
---

<MainLayout title={`标签 | ${siteConfig.title}`} description="按标签浏览全部文章。">
	<section class="shell page-intro">
		<p class="eyebrow">标签</p>
		<h1>按主题翻看文章</h1>
		<p class="page-intro__body">标签适合横向浏览同一主题下的文章，后续可以继续扩展，而不影响主栏目结构。</p>
	</section>

	<section class="shell tag-cloud section-block">
		{
			tags.map((tag) => (
				<a href={getTagHref(tag.name)}>
					<span>{tag.name}</span>
					<strong>{tag.count}</strong>
				</a>
			))
		}
	</section>
</MainLayout>
