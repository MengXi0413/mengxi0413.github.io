---
import MainLayout from '../../layouts/MainLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { siteConfig } from '../../config/site';
import { getAllTags, getPublishedPosts, slugifyTag } from '../../utils/content';

export async function getStaticPaths() {
	const posts = await getPublishedPosts();
	const tags = getAllTags(posts);

	return tags.map((tag) => ({
		params: { tag: slugifyTag(tag) },
		props: {
			tag,
			posts: posts.filter((post) => post.data.tags.includes(tag)),
		},
	}));
}

const { tag, posts } = Astro.props;
---

<MainLayout title={`${tag} | ${siteConfig.title}`} description={`查看与 ${tag} 相关的文章。`}>
	<section class="shell page-intro">
		<p class="eyebrow">标签</p>
		<h1>#{tag}</h1>
		<p class="page-intro__body">当前标签下共有 {posts.length} 篇文章。</p>
	</section>

	<section class="shell section-block">
		<div class="post-grid">
			{posts.map((post) => <PostCard post={post} compact />)}
		</div>
	</section>
</MainLayout>
