---
import MainLayout from '../layouts/MainLayout.astro';
import { siteConfig } from '../config/site';
import { getPublishedPosts } from '../utils/content';

const posts = await getPublishedPosts();
const groupedPosts = Array.from(
	posts.reduce((map, post) => {
		const year = post.data.pubDate.getFullYear();
		const current = map.get(year) ?? [];
		current.push(post);
		map.set(year, current);
		return map;
	}, new Map<number, typeof posts>()),
).sort((a, b) => b[0] - a[0]);
---

<MainLayout title={`归档 | ${siteConfig.title}`} description="按时间顺序查看全部文章。">
	<section class="shell page-intro">
		<p class="eyebrow">ARCHIVE</p>
		<h1>按时间回看写过的东西</h1>
		<p class="page-intro__body">这里按照年份整理所有公开文章，方便从时间线里回看自己的阶段变化。</p>
	</section>

	<section class="shell archive-stack section-block">
		{
			groupedPosts.map(([year, items]) => (
				<article class="archive-group">
					<h2>{year}</h2>
					<ul class="archive-list">
						{items.map((post) => (
							<li>
								<a href={`/posts/${post.id}/`}>
									<div>
										<strong>{post.data.title}</strong>
										<p>{post.data.description}</p>
									</div>
									<span>{post.data.pubDate.toLocaleDateString('zh-CN')}</span>
								</a>
							</li>
						))}
					</ul>
				</article>
			))
		}
	</section>
</MainLayout>
